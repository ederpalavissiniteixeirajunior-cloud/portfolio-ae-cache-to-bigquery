# ============================================================
# Environment variables for the VPS ingestion process.
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file — it is listed in .gitignore.
# ============================================================

# --- Google Cloud Platform ---
# Your GCP project ID where the BigQuery datasets live.
GCP_PROJECT_ID=your-gcp-project-id

# Target BigQuery dataset for raw (Bronze) ingestion loads.
GCP_DATASET_RAW=raw

# Absolute path to your GCP service account JSON key file.
# This file must also be excluded from git (covered by .gitignore).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/gcp-key.json

# --- Legacy Source (InterSystems Caché) ---
# ODBC DSN name configured on this server pointing to the Caché instance.
CACHE_DSN=YOUR_ODBC_DSN_NAME
